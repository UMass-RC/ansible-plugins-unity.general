<?xml version="1.0" encoding="UTF-8"?>
<AttributeFilterPolicyGroup id="ShibbolethFilterPolicy"
        xmlns="urn:mace:shibboleth:2.0:afp"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="urn:mace:shibboleth:2.0:afp http://shibboleth.net/schema/idp/shibboleth-afp.xsd">


    <!-- Release home org signifier to everybody. -->
    <AttributeFilterPolicy id="alwaysRelease">
        <PolicyRequirementRule xsi:type="ANY" />
        
        <AttributeRule attributeID="schacHomeOrganization" permitAny="true" />
    </AttributeFilterPolicy>

    <AttributeFilterPolicy id="releaseSlackEmail">
        <PolicyRequirementRule xsi:type="Requester"
            value="https://umass-amherst.enterprise.slack.com" />
        <AttributeRule attributeID="userEmail" permitAny="true" />
    </AttributeFilterPolicy>
</AttributeFilterPolicyGroup>
